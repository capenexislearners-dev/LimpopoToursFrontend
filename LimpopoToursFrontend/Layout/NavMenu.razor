@using LimpopoToursFrontend.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="sidebar">
    <div class="top-row ps-3 navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="">Limpopo Tours</a>
        </div>
    </div>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <div class="nav-scrollable">
        <nav class="flex-column">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="oi oi-home" aria-hidden="true"></span> Home
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="tours">
                    <span class="oi oi-map-marker" aria-hidden="true"></span> Tours
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="guides">
                    <span class="oi oi-person" aria-hidden="true"></span> Guides
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="bookings">
                    <span class="oi oi-calendar" aria-hidden="true"></span> Bookings
                </NavLink>
            </div>

            <hr class="text-white" />

            @if (AuthService.IsLoggedIn)
            {
                <div class="nav-item px-3">
                    <span class="nav-link text-white">👤 @AuthService.FullName</span>
                </div>
                <div class="nav-item px-3">
                    <button class="btn btn-outline-light btn-sm w-100" @onclick="Logout">
                        Logout
                    </button>
                </div>
            }
            else
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="oi oi-account-login" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="register">
                        <span class="oi oi-plus" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
            }
        </nav>
    </div>
</div>

@code {
    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}