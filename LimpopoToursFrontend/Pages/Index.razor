@page "/"

<div class="container mt-4">

    <!-- Hero Section -->
    <div class="p-5 mb-4 bg-dark text-white rounded-3">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold">🌍 Limpopo Tour Destinations</h1>
            <p class="col-md-8 fs-4">
                Discover the beauty of Limpopo. Explore our tours, meet our expert
                guides and book your next adventure today.
            </p>
            <a href="/tours" class="btn btn-success btn-lg me-2">View Tours</a>
            <a href="/bookings" class="btn btn-outline-light btn-lg">Book Now</a>
        </div>
    </div>

    <!-- Quick Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-header">Tours</div>
                <div class="card-body">
                    <h5 class="card-title">Explore Limpopo</h5>
                    <p class="card-text">Browse all available tours across Limpopo destinations.</p>
                    <a href="/tours" class="btn btn-light">View Tours</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-header">Guides</div>
                <div class="card-body">
                    <h5 class="card-title">Meet Our Guides</h5>
                    <p class="card-text">Our experienced guides know every corner of Limpopo.</p>
                    <a href="/guides" class="btn btn-light">View Guides</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3">
                <div class="card-header">Bookings</div>
                <div class="card-body">
                    <h5 class="card-title">Book Your Tour</h5>
                    <p class="card-text">Reserve your spot on any of our exciting Limpopo tours.</p>
                    <a href="/bookings" class="btn btn-light">Book Now</a>
                </div>
            </div>
        </div>
    </div>

</div>