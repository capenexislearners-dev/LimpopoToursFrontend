@page "/guides"
@using LimpopoToursFrontend.Models
@inject HttpClient Http

<h3 class="mb-4">Guides</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (successMessage != null)
{
    <div class="alert alert-success">@successMessage</div>
}

<!-- Create Guide Form -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">Add New Guide</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <input class="form-control" placeholder="Full Name" @bind="newGuide.FullName" />
            </div>
            <div class="col-md-4">
                <input class="form-control" placeholder="Language" @bind="newGuide.Language" />
            </div>
            <div class="col-md-4">
                <input class="form-control" placeholder="Bio" @bind="newGuide.Bio" />
            </div>
            <div class="col-md-12">
                <button class="btn btn-success" @onclick="CreateGuide">Add Guide</button>
            </div>
        </div>
    </div>
</div>

<!-- Guides Table -->
@if (guides == null)
{
    <p>Loading guides...</p>
}
else if (guides.Count == 0)
{
    <p>No guides found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Full Name</th>
                <th>Language</th>
                <th>Bio</th>
                <th>Tours</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var guide in guides)
            {
                <tr>
                    <td>@guide.FullName</td>
                    <td>@guide.Language</td>
                    <td>@guide.Bio</td>
                    <td>@guide.Tours.Count</td>
                    <td>
                        <button class="btn btn-danger btn-sm"
                                @onclick="() => DeleteGuide(guide.Id)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Guide>? guides;
    private Guide newGuide = new Guide();
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadGuides();
    }

    private async Task LoadGuides()
    {
        try
        {
            guides = await Http.GetFromJsonAsync<List<Guide>>("api/Guide");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load guides: {ex.Message}";
        }
    }

    private async Task CreateGuide()
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Guide", newGuide);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Guide created successfully!";
                newGuide = new Guide();
                await LoadGuides();
            }
            else
            {
                errorMessage = $"Failed to create guide: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    private async Task DeleteGuide(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/Guide/{id}");
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Guide deleted successfully!";
                await LoadGuides();
            }
            else
            {
                errorMessage = "Cannot delete guide with assigned tours.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }
}