@page "/tours"
@using LimpopoToursFrontend.Models
@inject HttpClient Http

<h3 class="mb-4">Tours</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (successMessage != null)
{
    <div class="alert alert-success">@successMessage</div>
}

<!-- Create Tour Form -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">Add New Tour</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <input class="form-control" placeholder="Tour Name" @bind="newTour.Name" />
            </div>
            <div class="col-md-6">
                <input class="form-control" placeholder="Location" @bind="newTour.Location" />
            </div>
            <div class="col-md-12">
                <input class="form-control" placeholder="Description" @bind="newTour.Description" />
            </div>
            <div class="col-md-4">
                <input class="form-control" type="number" placeholder="Price (R)" @bind="newTour.Price" />
            </div>
            <div class="col-md-4">
                <input class="form-control" type="number" placeholder="Duration (Days)" @bind="newTour.DurationDays" />
            </div>
            <div class="col-md-4">
                <input class="form-control" placeholder="Image URL (optional)" @bind="newTour.TourImageurl" />
            </div>
            <div class="col-md-12">
                <button class="btn btn-success" @onclick="CreateTour">Add Tour</button>
            </div>
        </div>
    </div>
</div>

<!-- Tours Table -->
@if (tours == null)
{
    <p>Loading tours...</p>
}
else if (tours.Count == 0)
{
    <p>No tours found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Location</th>
                <th>Price (R)</th>
                <th>Duration</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tour in tours)
            {
                <tr>
                    <td>@tour.Name</td>
                    <td>@tour.Location</td>
                    <td>R @tour.Price</td>
                    <td>@tour.DurationDays days</td>
                    <td>
                        <button class="btn btn-danger btn-sm"
                                @onclick="() => DeleteTour(tour.Id)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Tour>? tours;
    private Tour newTour = new Tour();
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadTours();
    }

    private async Task LoadTours()
    {
        try
        {
            tours = await Http.GetFromJsonAsync<List<Tour>>("api/Tour");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load tours: {ex.Message}";
        }
    }

    private async Task CreateTour()
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Tour", newTour);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Tour created successfully!";
                newTour = new Tour();
                await LoadTours();
            }
            else
            {
                errorMessage = $"Failed to create tour: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    private async Task DeleteTour(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/Tour/{id}");
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Tour deleted successfully!";
                await LoadTours();
            }
            else
            {
                errorMessage = "Cannot delete tour with existing bookings.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }
}