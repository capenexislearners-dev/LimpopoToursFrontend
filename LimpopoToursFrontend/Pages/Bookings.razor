@page "/bookings"
@using LimpopoToursFrontend.Models
@inject HttpClient Http

<h3 class="mb-4">Bookings</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (successMessage != null)
{
    <div class="alert alert-success">@successMessage</div>
}

<!-- Create Booking Form -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">Add New Booking</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <input class="form-control" placeholder="Customer Name"
                       @bind="newBooking.CustomerName" />
            </div>
            <div class="col-md-4">
                <input class="form-control" placeholder="Customer Email"
                       @bind="newBooking.CustomerEmail" />
            </div>
            <div class="col-md-4">
                <input class="form-control" type="number" placeholder="Number of People"
                       @bind="newBooking.NumberOfPeople" />
            </div>
            <div class="col-md-12">
                <select class="form-select" @bind="newBooking.TourId">
                    <option value="">-- Select a Tour --</option>
                    @if (tours != null)
                    {
                        @foreach (var tour in tours)
                        {
                            <option value="@tour.Id">@tour.Name - @tour.Location (R@tour.Price)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-12">
                <button class="btn btn-success" @onclick="CreateBooking">Add Booking</button>
            </div>
        </div>
    </div>
</div>

<!-- Bookings Table -->
@if (bookings == null)
{
    <p>Loading bookings...</p>
}
else if (bookings.Count == 0)
{
    <p>No bookings found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Customer Name</th>
                <th>Customer Email</th>
                <th>Tour</th>
                <th>People</th>
                <th>Booked At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in bookings)
            {
                <tr>
                    <td>@booking.CustomerName</td>
                    <td>@booking.CustomerEmail</td>
                    <td>@booking.TourName</td>
                    <td>@booking.NumberOfPeople</td>
                    <td>@booking.BookedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <button class="btn btn-danger btn-sm"
                                @onclick="() => DeleteBooking(booking.Id)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<BookingView>? bookings;
    private List<Tour>? tours;
    private Booking newBooking = new Booking();
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadTours();
        await LoadBookings();
    }

    private async Task LoadTours()
    {
        try
        {
            tours = await Http.GetFromJsonAsync<List<Tour>>("api/Tour");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load tours: {ex.Message}";
        }
    }

    private async Task LoadBookings()
    {
        try
        {
            bookings = await Http.GetFromJsonAsync<List<BookingView>>("api/Booking");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load bookings: {ex.Message}";
        }
    }

    private async Task CreateBooking()
    {
        errorMessage = null;
        successMessage = null;

        if (newBooking.TourId == Guid.Empty)
        {
            errorMessage = "Please select a tour.";
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/Booking", newBooking);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Booking created successfully!";
                newBooking = new Booking();
                await LoadBookings();
            }
            else
            {
                errorMessage = $"Failed to create booking: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    private async Task DeleteBooking(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/Booking/{id}");
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Booking deleted successfully!";
                await LoadBookings();
            }
            else
            {
                errorMessage = "Failed to delete booking.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    // This matches the shape returned by GET api/Booking
    public class BookingView
    {
        public Guid Id { get; set; }
        public string? CustomerName { get; set; }
        public string? CustomerEmail { get; set; }
        public DateTime BookedAt { get; set; }
        public int NumberOfPeople { get; set; }
        public string? TourName { get; set; }
    }
}